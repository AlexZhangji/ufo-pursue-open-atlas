# PURSUE Open Atlas — environment variables
#
# Copy this file to .env and fill in the keys you need. Each script
# only requires the variables it actually calls; you do not need every
# key set unless you re-run the entire pipeline end-to-end.

# ---- Repo root override ----
# Optional. Defaults to the parent dir of the script that imports it
# (resolved via Path(__file__).resolve().parent.parent), which is the
# correct behaviour after `git clone`. Set this only if your scripts
# live somewhere other than the repo root.
PURSUE_ROOT=

# ---- VLM extraction (pipeline/run_vlm_v3.py) ----
# Xiaomi MiMo Token Plan endpoint key. Format: tp-...
# (NOT the public sk-... endpoint — Token Plan billing is separate.)
MIMO_TP_KEY=
# Optional. Defaults to https://token-plan-sgp.xiaomimimo.com/v1
MIMO_TP_BASE_URL=
# Optional override for the VLM model name. Default: mimo-v2.5
MIMO_VLM_MODEL=
# Optional override for the render DPI / max dim used by the VLM
# pre-render step. Defaults: 200 / 2000.
PDF_VLM_DPI=
PDF_VLM_MAX_DIM=

# ---- Image-tag fallback (pipeline/run_fallback_mini.py) ----
# OpenAI key with access to gpt-5.4-mini. Format: sk-...
OPENAI_API_KEY=
